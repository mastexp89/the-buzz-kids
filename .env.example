# Copy this file to .env.local and fill in the values.
# Supabase keys: Dashboard → Project Settings → API.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Site ---
# Locally http://localhost:3000; in production your domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Claude event extraction ---
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-6

# --- Scraping (Apify) ---
APIFY_TOKEN=YOUR-APIFY-TOKEN

# --- Email (Resend) + admin notifications ---
RESEND_API_KEY=YOUR-RESEND-KEY
ADMIN_NOTIFY_FROM=hello@example.com
ADMIN_NOTIFY_EMAIL=admin@example.com

# --- Cron auth ---
CRON_SECRET=GENERATE-A-RANDOM-STRING

# --- Optional: Google Custom Search + Places ---
GOOGLE_CUSTOM_SEARCH_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
GOOGLE_PLACES_KEY=
